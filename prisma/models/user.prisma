enum UserRole {
    Customer
    AGENT
    ADMIN
}

model User {
    id        String   @id @default(uuid())
    fullName String
    email     String   @unique
    password  String
    avatarUrl String?
    role      UserRole @default(Customer)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
